# ── MoMo MCP Server configuration ───────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (it is git-ignored).
# Sandbox only — see Hard Rule #3. No production endpoints in this repo.

# ── MTN subscription keys (from momodeveloper.mtn.com → your subscriptions) ──
# Primary key of each subscribed product. Required.
MOMO_COLLECTION_SUBSCRIPTION_KEY=
MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=

# Optional: subscribed but NOT implemented in v1 (see spec §8.5).
MOMO_REMITTANCE_SUBSCRIPTION_KEY=

# ── API user / key (filled by scripts/provision.py — leave blank initially) ──
# The API user id IS a uuid4 generated during provisioning.
MOMO_API_USER=
MOMO_API_KEY=

# ── Environment / endpoints ─────────────────────────────────────────────────
MOMO_TARGET_ENV=sandbox
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_CALLBACK_HOST=https://example.com   # placeholder ok in sandbox
MOMO_CURRENCY=EUR                          # sandbox is EUR-only (prod RWA = RWF)

# ── Agent guardrails (spec §4.7) ────────────────────────────────────────────
DRY_RUN=true                               # default-safe: zero HTTP calls
REQUIRE_PAYOUT_APPROVAL=true               # payouts need confirm_payout()
MAX_AMOUNT_PER_TX=100
MAX_DAILY_TX_COUNT=50
MAX_DAILY_TOTAL=1000
# Comma-separated MSISDN allowlist. Sandbox default = magic test numbers only.
MSISDN_ALLOWLIST=46733123450,46733123451,46733123452,46733123453,46733123454

# ── Local store ─────────────────────────────────────────────────────────────
MOMO_DB_PATH=./data/momo.sqlite3

# ── Client-side rate limit (spec §4.5) ──────────────────────────────────────
RATE_LIMIT_PER_SEC=5
